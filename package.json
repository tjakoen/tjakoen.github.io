{
  "name": "tjakoen.github.io",
  "version": "0.1.0",
  "description": "tjakoen.github.io — a custom BATCH + GRAIN site that uses MILL for its content.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "author": "Tjakoen Stolk <tjakoen.s@gmail.com> (https://tjakoen.github.io)",
  "homepage": "https://tjakoen.github.io",
  "dependencies": {
    "@tjakoen/batch": "^0.1.0",
    "@tjakoen/crumb": "^0.1.1",
    "@tjakoen/grain": "^0.1.5",
    "@tjakoen/mill": "^0.1.0",
    "@tjakoen/proof": "^0.1.0"
  },
  "scripts": {
    "deps:refresh": "bun update @tjakoen/batch @tjakoen/crumb @tjakoen/grain @tjakoen/mill @tjakoen/proof",
    "dev": "bun --hot server.ts",
    "start": "bun server.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:all": "bun test && playwright test",
    "shots": "bun tools/screenshots.ts",
    "og:card": "bun tools/og-card.ts",
    "audit": "bun tools/audit.ts",
    "export": "bun tools/export.ts",
    "verify:export": "bun tools/verify-export.ts",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "bun-types": "^1.3.14",
    "typescript": "^5.8.0"
  },
  "exports": {
    "./docs/*": "./docs/*",
    "./standards/*": "./standards/*"
  }
