{
  "name": "tjakoen.github.io",
  "version": "0.1.0",
  "description": "tjakoen.github.io — a custom BATCH + GRAIN site that uses MILL for its content.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "author": "Tjakoen Stolk <tjakoen.s@gmail.com> (https://tjakoen.github.io)",
  "homepage": "https://tjakoen.github.io",
  "dependencies": {
    "@tjakoen/batch": "github:tjakoen/batch#5d04be0",
    "@tjakoen/grain": "github:tjakoen/grain#637630e",
    "@tjakoen/mill": "github:tjakoen/mill#2b85cb1",
    "@tjakoen/proof": "github:tjakoen/proof#19b444c"
  },
  "scripts": {
    "deps:refresh": "for p in batch grain mill proof; do bun add @tjakoen/$p@github:tjakoen/$p#$(git ls-remote https://github.com/tjakoen/$p.git main | cut -c1-7); done",
    "dev": "bun --hot server.ts",
    "start": "bun server.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:all": "bun test && playwright test",
    "shots": "bun tools/screenshots.ts",
    "audit": "bun tools/audit.ts",
    "export": "bun tools/export.ts",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "bun-types": "^1.3.14",
    "typescript": "^5.8.0"
  },
  "exports": {
    "./docs/*": "./docs/*",
    "./standards/*": "./standards/*"
  }
}
